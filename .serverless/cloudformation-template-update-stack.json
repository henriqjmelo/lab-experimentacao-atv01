    "S3BucketDataprocessingbucketlocal": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": "data-processing-bucket-local",
        "NotificationConfiguration": {
          "LambdaConfigurations": [
            {
              "Event": "s3:ObjectCreated:*",
              "Function": {
                "Fn::GetAtt": [
                  "DataProcessorLambdaFunction",
                  "Arn"
                ]
              },
              "Filter": {
                "S3Key": {
                  "Rules": [
                    {
                      "Name": "prefix",
                      "Value": "input/"
                    },
                    {
                      "Name": "suffix",
                      "Value": ".csv"
                    }
                  ]
                }
              }
            }
          ]
        }
      },
      "DependsOn": [
        "DataProcessorLambdaPermissionDataprocessingbucketlocalS3"
      ]
    },
    "DataProcessorLambdaPermissionDataprocessingbucketlocalS3": {
      "Type": "AWS::Lambda::Permission",
      "Properties": {
        "FunctionName": {
